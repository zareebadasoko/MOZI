# 챗봇 API 서버 환경변수 템플릿
# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요. .env 는 절대 커밋되지 않습니다.
#   cp .env.example .env

# ── 필수 ────────────────────────────────────────────────
# OpenAI: LLM(gpt-4.1-mini, gpt-4.1-nano) + 임베딩(text-embedding-3-large)
OPENAI_API_KEY=

# 본 서버 인증용 X-API-Key (백엔드가 호출 시 사용하는 키와 동일해야 함)
CHATBOT_API_KEY=dev-key-change-me

# ── 선택 ────────────────────────────────────────────────
# 인덱스 디렉토리 (기본: api/vectorstores/)
# INDEX_DIR=

# 원본 데이터 경로 (기본: api/data/welfare_integrated_all.json)
# WELFARE_DATA_PATH=

# LangSmith 추적 (true 일 때만 LANGSMITH_API_KEY 필요)
# LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
